#include <stdio.h>

int legnagyobboszto(int n) {
    int d;

    if (n <= 1) {
        return 1;        
    }

    for (d = n / 2; d >= 1; d--) {  
        if (n % d == 0) {
            return d;      
        }
    }

    return 1;              
}

int main(void) {
    for (int i = 1; i <= 50; i++) {
        printf("%2d: %d\n", i, legnagyobboszto(i));
    }
    return 0;
}
