#include <stdio.h>

/* A) feladat */
int legkisebb(const int a[], int n) {
    int min = a[0];
    for (int i = 1; i < n; i++) {
        if (a[i] < min) {
            min = a[i];
        }
    }
    return min;
}

/* B) feladat */
int legnagyobb(const int a[], int n) {
    int max = a[0];
    for (int i = 1; i < n; i++) {
        if (a[i] > max) {
            max = a[i];
        }
    }
    return max;
}

int main(void) {
    int t[] = {5, -2, 7, 0, 3};
    int n = sizeof(t) / sizeof(t[0]);

    printf("Legkisebb: %d\n", legkisebb(t, n));
    printf("Legnagyobb: %d\n", legnagyobb(t, n));

    return 0;
}
