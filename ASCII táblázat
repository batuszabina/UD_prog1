#include <stdio.h>
int main(){
int i;
int s =0;

    printf("Az ASCII tabla 32-től 126-ig: \n");

    for(i=32; i<=126; i++){
    printf("%d: %c\n",i ,i); //%c-karakter, %d-tizedes
    }

    for(i='A'; i<='Z'; i++){
        s+=i;   
    }
    printf("Ezen értékek összege: %d\n",s);
    
    return 0;
}
