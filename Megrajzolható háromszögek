#include <stdio.h>

int valid_triangle(int a, int b, int c) {
    if (a <= 0 || b <= 0 || c <= 0) {
        return 0;
    }

    if (a + b <= c) return 0;
    if (a + c <= b) return 0;
    if (b + c <= a) return 0;

    return 1;
}

int main(void) {
    int a, b, c;

    printf("Add meg a haromszog harom oldalat: ");
    scanf("%d %d %d", &a, &b, &c);

    if (valid_triangle(a, b, c) == 1) {
        printf("Megrajzolható a háromszög.\n");
    } else {
        printf("NEM megrajzolható a háromszög.\n");
    }

    return 0;
}
