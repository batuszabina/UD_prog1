#include<stdio.h>
#include<string.h>
#include "prog1.h"

int match_ends(int x, char *words[]) {
    int szamlalo = 0;
    for(int i=0; i<x; i++) {
        int len = strlen(words[i]);
        if(len >= 2 && words[i][0] == words[i][len-1]) {
            szamlalo++;
        }
    }
    return szamlalo;
}

int main() {

    char *szavak[]={"aba", "xyz", "aa", "x", "bbb"};
    int szavak1_meret = 5;
    int eredmeny = match_ends(szavak1_meret, szavak);
    printf("Eredmeny: %d\n", eredmeny);

    return 0;
}
