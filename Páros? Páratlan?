#include <stdio.h>

int is_even(int n) {
    if (n % 2 == 0) {
        return 1; 
    } else {
        return 0; 
    }
}

/* B része */
int is_odd(int n) {
    return !is_even(n);
}

int main(void) {
    int x;

    printf("Adj meg egy egesz szamot: ");
    scanf("%d", &x);

    printf("is_even(%d) = %d\n", x, is_even(x));
    printf("is_odd(%d)  = %d\n", x, is_odd(x));

    return 0;
}
