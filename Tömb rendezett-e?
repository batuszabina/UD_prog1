#include <stdio.h>

int rendezette(const int a[], int n) {   /* függvény fej deklarációval */
    for (int i = 1; i < n; i++) {
        if (a[i] < a[i - 1]) {
            return 0;
        }
    }
    return 1;
}

int main(void) {
    int t1[] = {1, 2, 2, 5, 8};
    int t2[] = {3, 1, 4, 2};

    int n1 = sizeof(t1) / sizeof(t1[0]);
    int n2 = sizeof(t2) / sizeof(t2[0]);

    printf("t1 rendezett? %d\n", rendezette(t1, n1));
    printf("t2 rendezett? %d\n", rendezette(t2, n2));

    return 0;
}
