#include <stdio.h>
#include <stdlib.h> 

void pozitivva_alakit(int tomb[], int meret) {
    for (int i = 0; i < meret; i++) {
        if (tomb[i] < 0) {
            tomb[i] = abs(tomb[i]);
        }
    }
}

void tomb_kiir(const int tomb[], int meret) {
    for (int i = 0; i < meret; i++) {
        printf("%d ", tomb[i]);
    }
    printf("\n");
}

int main(void)
{
    int szamok[] = {3, -5, 0, 12, -7, -1};
    int n = sizeof(szamok) / sizeof(szamok[0]);
    tomb_kiir(szamok, n);
    pozitivva_alakit(szamok, n);
    tomb_kiir(szamok, n);

    return 0;
}
