#include <stdio.h>

void print_array(const int arr[], int size) {
    for (int i = 0; i < size; i++) {
        printf("%d", arr[i]);
        if (i < size - 1) {
            printf(", ");
        }
    }
    printf("\n");
}

int main(void) {
    int tomb[] = {4, 7, 34, 23, 67};
    int n = sizeof(tomb) / sizeof(tomb[0]);
    print_array(tomb, n);

    return 0;
}
